{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": false,
    "paths": {
      "electron": ["./node_modules/@devscholar/node-with-window/dist/index.js"]
    }
  },
  "include": ["src/**/*"]
}
